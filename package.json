{
  "name": "patreon-x-revo",
  "version": "1.0.0",
  "description": "Sync Patreon pledges to Discord roles via OAuth linking and webhooks",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/db/migrate.js && node dist/index.js",
    "check": "tsx src/scripts/check-env.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "reconcile": "tsx src/jobs/reconcile.ts",
    "provision": "tsx src/jobs/provision.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.1",
    "better-sqlite3": "^11.9.1",
    "discord.js": "^14.19.3",
    "dotenv": "^16.5.0",
    "hono": "^4.7.8",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
